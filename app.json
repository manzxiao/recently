{
  "expo": {
    "name": "recently",
    "slug": "recently",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "recently",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.manzxiao.recently",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-background-task",
      "@react-native-community/datetimepicker",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.manzxiao.recently.widgets",
          "groupIdentifier": "group.com.manzxiao.recently",
          "widgets": [
            {
              "name": "EventWidget",
              "displayName": "时光簿",
              "description": "显示最近即将到来的事件",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge",
                "accessoryInline",
                "accessoryRectangular",
                "accessoryCircular"
              ]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2b20d716-390c-41dc-9e4b-13e71093cb3a"
      }
    }
  }
}
